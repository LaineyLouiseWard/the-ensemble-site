# GitHub fine-grained PAT with read-only Discussions access.
# Powers the converge/diverge reaction feature (/api/ensemble).
# Contributors do NOT need this for writing or previewing posts.
GITHUB_TOKEN=

# ── Page view counter (optional, Upstash Redis) ──
# If not configured, views display as blank (no error).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
