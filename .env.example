# GitHub fine-grained PAT with read-only Discussions access.
# Powers the converge/diverge reaction feature (/api/ensemble).
# Contributors do NOT need this for writing or previewing posts.
GITHUB_TOKEN=

# ── Page view counter (optional) ──
# Set ONE pair to enable view counts on blog posts.
# If neither is configured, views display as blank (no error).

# Option A: Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Option B: Cloudflare KV (bind VIEWS_KV_NAMESPACE in wrangler.toml)
