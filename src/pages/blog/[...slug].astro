---
import { type CollectionEntry, getCollection, getEntry } from 'astro:content'
import BlogPostLayout from '../../layouts/BlogPostLayout.astro'
import type { MarkdownHeading } from 'astro'

export async function getStaticPaths() {
	const posts = await getCollection('blog')
	const headings = await Promise.all(
		posts.map(async (post) => {
			const data = await post.render()
			return data.headings
		})
	)
	return posts.map((post, index) => ({
		params: { slug: post.slug },
		props: { post, headings: headings[index], slug: post.slug },
	}))
}

type Props = {
	post: CollectionEntry<'blog'>
	headings: MarkdownHeading[]
	slug: string
}

const { post, headings, slug } = Astro.props
const { Content, remarkPluginFrontmatter } = await post.render()

const resolvedAuthors = (
	await Promise.all(
		(post.data.authors || []).map((id: string) => getEntry('authors', id))
	)
).filter((a): a is NonNullable<typeof a> => Boolean(a))

const { authors: _authorSlugs, ...postData } = post.data
---

<BlogPostLayout
	{...postData}
	headings={headings}
	slug={slug}
	remarkPluginFrontmatter={remarkPluginFrontmatter}
	authors={resolvedAuthors}
>
	<Content />
</BlogPostLayout>
