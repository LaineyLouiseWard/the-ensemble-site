---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout hero>
	<div class="relative w-full min-h-screen overflow-hidden">
		<!-- Parallax landscape background -->
		<div class="absolute inset-0" style="image-rendering: pixelated;">
			<div class="absolute inset-0" style="background: url('/parallax/1.png') repeat-x center bottom / auto 120%;"></div>
			<div class="absolute inset-0" style="background: url('/parallax/3.png') repeat-x center calc(100% + 35px) / auto 120%;"></div>
			<div class="absolute inset-0" style="background: url('/parallax/4.png') repeat-x -120px calc(100% + 45px) / auto 120%;"></div>
		</div>

		<!-- Overlay -->
		<div class="absolute inset-0 bg-black/40 dark:bg-black/60"></div>

		<!-- Content -->
		<main class="relative flex flex-col items-center justify-center min-h-screen px-4 text-center text-white" style="z-index: 10;">
			<img
				src="/avatars/lainey.png"
				alt=""
				class="h-20 w-auto mb-6 opacity-70 pixel-idle"
				style="image-rendering: pixelated;"
			/>
			<h1 class="font-display text-8xl md:text-9xl font-bold leading-none mb-4">
				404
			</h1>
			<p class="font-display text-xl md:text-2xl text-white/80 max-w-md mb-8">
				You've wandered off the path.
			</p>
			<a
				href="/"
				class="font-meta text-sm uppercase tracking-[0.15em] px-5 py-2.5 border border-white/50 rounded text-white/90 hover:bg-white/10 hover:text-white transition-colors"
			>
				Back to camp
			</a>
		</main>
	</div>
</BaseLayout>
