---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogCard from '../../components/BlogCard.astro'
import TrackHero from '../../components/TrackHero.astro'
import { TRACKS } from '../../consts'

// Layers listed back → front. All drift rightward; front layer is fastest.
const TRACK_LAYERS: Record<string, string[]> = {
	'phd-tips':   [2, 3, 4, 5].map((n) => `/banners/phd-tips/${n}.png`),
	'events':     [1, 2, 3, 4, 5, 6].map((n) => `/banners/events/${n}.png`),
	'discussion': [1, 2, 3, 4, 5].map((n) => `/banners/discussion/${n}.png`),
	'research':   [1, 2, 3, 4].map((n) => `/banners/research/${n}.png`),
}

// Per-track overrides — cloud (layer 3) and reflection (layer 4) share speed + offset
const TRACK_SPEEDS: Record<string, number[]> = {
	'phd-tips': [800, 300, 300, 150],
}
const TRACK_INIT_X: Record<string, number[]> = {
	'phd-tips': [0, 0, 0, 50],
}

export function getStaticPaths() {
	return TRACKS.map((track) => ({
		params: { track: track.slug },
		props: { label: track.label },
	}))
}

const { track } = Astro.params
const { label } = Astro.props

const posts = (await getCollection('blog'))
	.filter((post) => post.data.track === track)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
---

<BaseLayout title={label} description={`Articles in the ${label} track.`} hero>
	<TrackHero
		layers={TRACK_LAYERS[track!] ?? []}
		label={label}
		zoom={track === 'phd-tips' ? 1.2 : 1}
		speeds={TRACK_SPEEDS[track!]}
		initX={TRACK_INIT_X[track!]}
	/>

	<!-- Posts -->
	<section class="app-container pt-10 md:pt-12 pb-10 md:pb-12">
		{
			posts.length > 0 ? (
				<div class="grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
					{posts.map((post) => (
						<BlogCard post={post} />
					))}
				</div>
			) : (
				<p class="text-lg opacity-50">No posts in this track yet.</p>
			)
		}
	</section>
</BaseLayout>
