---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { TRACKS } from '../../consts'
import { getCollection } from 'astro:content'

const posts = await getCollection('blog')

const tracksWithCounts = TRACKS.map((track) => ({
	...track,
	count: posts.filter((p) => p.data.track === track.slug).length,
}))
---

<BaseLayout title="Tracks" description="Browse articles by track.">
	<main class="app-container pt-36">
		<h1 class="text-6xl pb-8 font-bold">Tracks</h1>
		<p class="md:w-2/3 text-lg leading-[2rem]">
			Browse articles by topic.
		</p>
	</main>
	<section class="app-container py-12">
		<div class="grid gap-4 sm:grid-cols-2">
			{
				tracksWithCounts.map((track) => (
					<a
						href={`/tracks/${track.slug}/`}
						class="flex items-center justify-between p-6 rounded-xl hover:bg-foreground/5 dark:hover:bg-foreground-dark/5 transition-colors group"
					>
						<span class="text-xl font-semibold group-hover:text-primary dark:group-hover:text-primary-dark transition-colors">
							{track.label}
						</span>
						<span class="text-sm opacity-50">
							{track.count} {track.count === 1 ? 'post' : 'posts'}
						</span>
					</a>
				))
			}
		</div>
	</section>
</BaseLayout>
