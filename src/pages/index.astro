---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE_TITLE, SITE_DESCRIPTION, TRACKS } from '../consts'
import BlogCard from '../components/BlogCard.astro'
import FeaturedCard from '../components/FeaturedCard.astro'
import ParallaxHero from '../components/ParallaxHero.astro'
import { getCollection } from 'astro:content'

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)

const featured = allPosts.filter((p) => p.data.featured)
const latest = allPosts.filter((p) => !p.data.featured)

const authors = await getCollection('authors')
const heroAvatars = authors.map((a) => ({
	id: a.id,
	avatar: a.data.avatar,
	name: a.data.name,
}))
---

<BaseLayout hero>
	<!-- First fold: hero + strip + featured fill the viewport -->
	<div class="min-h-screen flex flex-col">
		<!-- Hero -->
		<ParallaxHero avatars={heroAvatars}>
			<div
				class="h-full app-container pt-36"
			>
				<h1
					class="font-display text-6xl font-bold text-white leading-[1.05] tracking-[-0.01em]"
				>
					{SITE_TITLE}
				</h1>
				<p class="text-xl text-white/90 mt-5 max-w-lg font-semibold leading-[1.5]">
					{SITE_DESCRIPTION}
				</p>
			</div>
		</ParallaxHero>

		<!-- Category strip -->
		<nav
			class="border-y border-foreground/10 dark:border-foreground-dark/10"
		>
			<div
				class="app-container flex items-center justify-between py-4"
			>
				{
					TRACKS.map((track) => (
						<a
							href={`/tracks/${track.slug}/`}
							class="font-meta text-[11px] sm:text-xs uppercase tracking-[0.2em] text-foreground/70 dark:text-foreground-dark/70 hover:text-foreground/90 dark:hover:text-foreground-dark/90 font-medium whitespace-nowrap transition-colors flex items-center gap-1.5"
						>
							<img src={`/icons/tracks/${track.slug}.png`} alt="" class="w-4 h-4 sm:w-5 sm:h-5 pixel-hop" style="image-rendering: pixelated;" />
							{track.label}
						</a>
					))
				}
			</div>
		</nav>

		<!-- Featured — grows to fill remaining viewport, content vertically centered -->
		<section class="app-container flex-1 flex flex-col justify-center">
			<h2 class="font-meta text-xs uppercase tracking-[0.2em] text-foreground/70 dark:text-foreground-dark/70 font-medium mb-4">Featured</h2>
			<div class="grid gap-14 md:grid-cols-2">
				{featured.map((post) => <FeaturedCard post={post} />)}
			</div>
		</section>
	</div>

	<!-- Latest -->
	{
		latest.length > 0 && (
			<section class="app-container pt-16 pb-24">
				<h2 class="font-meta text-xs uppercase tracking-[0.2em] text-foreground/70 dark:text-foreground-dark/70 font-medium mb-8">
					Latest
				</h2>
				<div class="grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
					{latest.map((post) => (
						<BlogCard post={post} />
					))}
				</div>
			</section>
		)
	}

</BaseLayout>
