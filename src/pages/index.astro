---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE_TITLE, SITE_DESCRIPTION, TRACKS } from '../consts'
import BlogCard from '../components/BlogCard.astro'
import FeaturedCard from '../components/FeaturedCard.astro'
import ParallaxHero from '../components/ParallaxHero.astro'
import { getCollection } from 'astro:content'

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)

const featured = allPosts.slice(0, 2)
const latest = allPosts.slice(2)
---

<BaseLayout hero>
	<!-- Hero -->
	<ParallaxHero>
		<div
			class="h-full app-container pt-36"
		>
			<h1
				class="font-display text-6xl font-bold text-white leading-[1.05] tracking-[-0.01em]"
			>
				{SITE_TITLE}
			</h1>
			<p class="text-xl text-white/90 mt-5 max-w-lg font-semibold leading-[1.5]">
				{SITE_DESCRIPTION}
			</p>
		</div>
	</ParallaxHero>

	<!-- Category strip -->
	<nav
		class="border-y border-foreground/10 dark:border-foreground-dark/10"
	>
		<div
			class="app-container flex items-center justify-between py-4"
		>
			{
				TRACKS.map((track) => (
					<a
						href={`/tracks/${track.slug}/`}
						class="text-[13px] sm:text-sm uppercase tracking-[0.35em] text-foreground/65 dark:text-foreground-dark/65 hover:text-foreground/85 dark:hover:text-foreground-dark/85 font-semibold whitespace-nowrap transition-colors"
					>
						{track.label}
					</a>
				))
			}
		</div>
	</nav>

	<!-- Featured -->
	<section class="app-container pt-10 pb-12">
		<h2 class="text-sm uppercase tracking-[0.3em] text-foreground/70 dark:text-foreground-dark/70 font-semibold mb-8">Featured</h2>
		<div class="grid gap-8 md:grid-cols-2">
			{featured.map((post) => <FeaturedCard post={post} />)}
		</div>
	</section>

	<!-- Latest -->
	{
		latest.length > 0 && (
			<section class="app-container pb-24">
				<h2 class="text-sm uppercase tracking-[0.3em] text-foreground/70 dark:text-foreground-dark/70 font-semibold mb-8">
					Latest
				</h2>
				<div class="grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
					{latest.map((post) => (
						<BlogCard post={post} />
					))}
				</div>
			</section>
		)
	}
</BaseLayout>
