---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogCard from '../../components/BlogCard.astro'

export async function getStaticPaths() {
	const authors = await getCollection('authors')
	const posts = await getCollection('blog')

	return authors.map((author) => {
		const authorPosts = posts
			.filter((post) => post.data.authors.includes(author.id))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
		return {
			params: { slug: author.id },
			props: { author, posts: authorPosts },
		}
	})
}

const { author, posts } = Astro.props
const { name, role, affiliation, bio, avatar, linkedin, orcid, website, github, links } = author.data
const socials = [
	linkedin && { href: linkedin, icon: '/icons/social/linkedin.svg', label: 'LinkedIn' },
	orcid && { href: orcid, icon: '/icons/social/orcid.svg', label: 'ORCID' },
	github && { href: github, icon: '/icons/social/github.svg', label: 'GitHub' },
	website && { href: website, icon: '/icons/social/website.svg', label: 'Website' },
].filter(Boolean) as { href: string; icon: string; label: string }[]
---

<BaseLayout title={name} description={bio}>
	<main class="app-container pt-36">
		<div class="flex flex-col sm:flex-row items-start gap-8 pb-12">
			<img
				src={avatar}
				alt={name}
				class="h-28 w-auto object-contain shrink-0 pixel-hop"
				style="image-rendering: pixelated;"
			/>
			<div>
				<h1 class="text-4xl sm:text-5xl font-bold">{name}</h1>
				<p class="text-lg opacity-70 mt-2">{role}</p>
				{affiliation && <p class="opacity-50 mt-1">{affiliation}</p>}
				{
					socials.length > 0 && (
						<div class="flex gap-3 mt-3">
							{socials.map((s) => (
								<a
									href={s.href}
									target="_blank"
									rel="noopener noreferrer"
									aria-label={s.label}
									class="opacity-60 hover:opacity-100 transition-opacity"
								>
									<img
										src={s.icon}
										alt={s.label}
										class="h-5 w-5 dark:invert"
										style="image-rendering: crisp-edges;"
									/>
								</a>
							))}
						</div>
					)
				}
				{bio.split('\n\n').map((para) => (
					<p class="text-lg mt-4 max-w-2xl">{para}</p>
				))}
				{
					links && links.length > 0 && (
						<div class="flex flex-wrap gap-4 mt-4">
							{links.map((link) => (
								<a
									href={link.url}
									target="_blank"
									rel="noopener noreferrer"
									class="text-primary dark:text-primary-dark underline underline-offset-4"
								>
									{link.label}
								</a>
							))}
						</div>
					)
				}
			</div>
		</div>
	</main>
	<section class="app-container pb-24">
		<h2 class="section-title">
			Posts by {name}
		</h2>
		{
			posts.length > 0 ? (
				<div class="posts-grid-container">
					{posts.map((post) => (
						<BlogCard post={post} />
					))}
				</div>
			) : (
				<p class="text-lg opacity-70">No posts yet.</p>
			)
		}
	</section>
</BaseLayout>
