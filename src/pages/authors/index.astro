---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

const allAuthors = await getCollection('authors')
const allPosts = await getCollection('blog')
const postCountByAuthor = new Map<string, number>()
allPosts.forEach((post) => {
	(post.data.authors || []).forEach((id: string) => {
		postCountByAuthor.set(id, (postCountByAuthor.get(id) || 0) + 1)
	})
})
const authors = allAuthors.sort((a, b) => {
	if (a.id === 'lainey') return -1
	if (b.id === 'lainey') return 1
	return a.data.name.localeCompare(b.data.name)
})
---

<BaseLayout title="The Ensemble" description="The people behind The Ensemble Edit.">
	<main class="app-container pt-36">
		<h1 class="text-6xl pb-8 font-bold">The Ensemble</h1>
		<p class="md:w-2/3 text-lg leading-[2rem]">
			The people who write here. Want to join?
			<a href="/blog/instructions-for-authors/" class="underline underline-offset-4 hover:text-primary dark:hover:text-primary-dark transition-colors">Get started</a>.
		</p>
	</main>
	<section class="app-container py-12">
		<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
			{
				authors.map((author) => (
					<a
						href={`/authors/${author.id}/`}
						class="flex flex-col items-center gap-4 p-6 rounded-xl hover:bg-foreground/5 dark:hover:bg-foreground-dark/5 transition-colors group"
					>
						<img
							src={author.data.avatar}
							alt={author.data.name}
							class="h-24 w-auto object-contain"
							style="image-rendering: pixelated;"
						/>
						<div class="text-center">
							<h2 class="text-xl font-semibold group-hover:text-primary dark:group-hover:text-primary-dark transition-colors">
								{author.data.name}
							</h2>
							<p class="font-meta text-xs opacity-70 mt-1">{author.data.role}</p>
							{author.data.affiliation && (
								<p class="font-meta text-xs opacity-50 mt-0.5">
									{author.data.affiliation}
								</p>
							)}
							{(postCountByAuthor.get(author.id) || 0) > 0 && (
								<p class="font-meta text-xs opacity-40 mt-1.5">
									{postCountByAuthor.get(author.id)} {postCountByAuthor.get(author.id) === 1 ? 'article' : 'articles'}
								</p>
							)}
						</div>
					</a>
				))
			}
		</div>
		<!-- Join the Ensemble card — centered below the grid -->
		<div class="flex justify-center mt-8">
			<a
				href="/blog/instructions-for-authors/"
				class="flex flex-col items-center justify-center gap-4 p-6 rounded-xl border-2 border-dashed border-foreground/20 dark:border-foreground-dark/20 hover:border-foreground/40 dark:hover:border-foreground-dark/40 transition-colors group min-h-[200px] w-full max-w-sm"
			>
				<span class="text-4xl opacity-30 group-hover:opacity-50 transition-opacity">+</span>
				<div class="text-center">
					<h2 class="text-lg font-semibold group-hover:text-primary dark:group-hover:text-primary-dark transition-colors">
						Join the Ensemble
					</h2>
					<p class="font-meta text-xs opacity-50 mt-1">We'd love to hear your voice</p>
				</div>
			</a>
		</div>
	</section>
</BaseLayout>
