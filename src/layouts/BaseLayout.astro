---
import BaseHead from '../components/BaseHead.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts'

interface Props {
	title?: string
	description?: string
	hero?: boolean
}

const { title, description, hero = false } = Astro.props

import '@fontsource-variable/inter'
import '@fontsource-variable/jetbrains-mono'
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={title || SITE_TITLE}
			description={description || SITE_DESCRIPTION}
		/>
	</head>
	<body
		class="text-foreground bg-background font-light dark:text-foreground-dark dark:bg-background-dark transition-colors"
	>
		<Navbar title={SITE_TITLE} transparent={hero} />
		<slot />
		<Footer />
		<script is:inline>
		(function () {
			if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return
			document.addEventListener('mouseenter', function (e) {
				var el = e.target.closest('.pixel-hop')
				if (!el) return
				var container = el.parentElement
				if (!container) return
				var cs = getComputedStyle(container)
				if (cs.position === 'static') container.style.position = 'relative'
				var rect = el.getBoundingClientRect()
				var cRect = container.getBoundingClientRect()
				var baseBottom = cRect.bottom - rect.bottom
				var baseLeft = rect.left - cRect.left
				var w = rect.width
				for (var i = 0; i < 5; i++) {
					var d = document.createElement('span')
					d.className = 'pixel-dust'
					d.style.setProperty('--dust-x', (Math.random() * 16 - 8) + 'px')
					d.style.setProperty('--dust-y', (6 + Math.random() * 10) + 'px')
					d.style.left = (baseLeft + w * (0.1 + Math.random() * 0.8)) + 'px'
					d.style.bottom = baseBottom + 'px'
					d.style.animationDelay = (Math.random() * 80) + 'ms'
					container.appendChild(d)
					d.addEventListener('animationend', function () { d.remove() })
				}
			}, true)
		})()
		</script>
	</body>
</html>
