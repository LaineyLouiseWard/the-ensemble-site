---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import FormattedDate from '../components/FormattedDate.astro'
import CommentsGiscus from '../components/CommentsGiscus.astro'
import ViewCount from '../components/ViewCount.astro'
import EnsembleResponse from '../components/EnsembleResponse.astro'
import type { MarkdownHeading, ImageMetadata } from 'astro'
import TableOfContents from '../components/TableOfContents.astro'
import dayjs from 'dayjs'
import utc from 'dayjs/plugin/utc'

dayjs.extend(utc)

type Props = Omit<CollectionEntry<'blog'>['data'], 'authors'> & {
	headings: MarkdownHeading[]
	slug: string
	remarkPluginFrontmatter: Record<string, string>
	authors?: CollectionEntry<'authors'>[]
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	coverImageCredit,
	headings,
	slug,
	remarkPluginFrontmatter,
	authors = [],
	tags = [],
	track,
} = Astro.props

const allPosts = await getCollection('blog')
const morePosts = allPosts
	.filter((p) => p.data.track === track && p.slug !== slug)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3)

import BaseLayout from './BaseLayout.astro'
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import BlogCard from '../components/BlogCard.astro'

const blogImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/blogimages/**/*.{jpeg,jpg,png,gif}'
)

const coverImagePath = blogImages[`/src/assets/blogimages/${slug}/cover.jpg`]
	? `/src/assets/blogimages/${slug}/cover.jpg`
	: `/src/assets/blogimages/${slug}/cover.png`

const lastModified = dayjs(remarkPluginFrontmatter.lastModified)
	.utc()
	.format('D MMM YYYY')
---

<BaseLayout title={title} description={description}>
	<main>
		<article>
			<div
				class="app-container flex flex-col lg:flex-row-reverse justify-between gap-8 py-24 relative"
			>
				<div class="md:w-1/4 relative">
					<div class="sticky top-0 md:top-28 hidden lg:block">
						<TableOfContents headings={headings} />
					</div>
				</div>
				<div class="grow w-full md:max-w-[75ch]">
					<div>
						<h1 class="font-display text-4xl sm:text-5xl leading-[1.1] pt-12 font-bold tracking-[-0.01em]">
							{title}
						</h1>
						<div class="text-lg flex items-center gap-4 flex-wrap py-8">
							<!-- Publish date -->
							<span>
								<Icon
									name="mdi:calendar-month-outline"
									class="inline-block text-primary dark:text-primary-dark"
								/>
								<FormattedDate date={pubDate} />
							</span>

							<!-- Updated date -->
							{
								updatedDate && (
									<span>
										<Icon
											name="mdi:calendar-refresh-outline"
											class="inline-block text-primary dark:text-primary-dark"
										/>
										Last updated on <FormattedDate date={updatedDate} />
									</span>
								)
							}

							<!-- Read time -->
							<span>
								<Icon
									name="mdi:clock-time-four-outline"
									class="inline-block text-primary dark:text-primary-dark"
								/>
								{remarkPluginFrontmatter.minutesRead}
							</span>

							<!-- View count -->
							<span>
								<Icon
									name="mdi:eye-outline"
									class="inline-block text-primary dark:text-primary-dark"
								/>
								<ViewCount slug={slug} />
							</span>
						</div>

						{
							authors.length > 0 && (
								<div class="flex flex-wrap gap-4 pb-8">
									{authors.map((author) => (
										<a
											href={`/authors/${author.id}/`}
											class="flex items-center gap-3 hover:opacity-75 transition-opacity"
										>
											<img
												src={author.data.avatar}
												alt={author.data.name}
												class="h-10 w-auto object-contain pixel-hop"
												style="image-rendering: pixelated;"
											/>
											<div>
												<span class="font-medium">
													{author.data.name}
												</span>
												<span class="block text-sm opacity-60">
													{author.data.role}
												</span>
											</div>
										</a>
									))}
								</div>
							)
						}

						{
							blogImages[coverImagePath] && (
								<div class="mb-8">
									<Image
										src={blogImages[coverImagePath]()}
										alt={title}
										class="rounded-lg"
									/>
									{coverImageCredit && (
										<p class="mt-2 opacity-80 italic text-sm">
											Image Credit: {coverImageCredit}
										</p>
									)}
								</div>
							)
						}
					</div>
					<div
						class="prose prose-neutral prose-lg md:prose-xl dark:prose-invert prose-img:rounded-xl prose-figure:text-center prose-img:mx-auto"
					>
						<slot />
					</div>

					{tags.length > 0 && (
						<div class="flex flex-wrap gap-2 mt-8">
							{tags.map((tag) => (
								<a
									href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}/`}
									class="tag-pill font-meta text-xs px-2.5 py-1 rounded-full border border-foreground/15 dark:border-foreground-dark/15 text-foreground/60 dark:text-foreground-dark/60 hover:border-foreground/30 dark:hover:border-foreground-dark/30 hover:text-foreground/80 dark:hover:text-foreground-dark/80 transition-colors"
								>
									#{tag}
								</a>
							))}
						</div>
					)}

					<!-- Suggest edit -->
					<div class="flex justify-between mt-16 gap-4 flex-wrap italic">
						<a
							href={`https://github.com/LaineyLouiseWard/the-ensemble-site/edit/main/src/content/blog/${slug}.md`}
							target="_blank"
							rel="noopener noreferrer"
							class="hover:underline underline-offset-4 opacity-70 hover:opacity-100"
							><Icon name="mdi:pencil-outline" class="inline-block" />
							Suggest an edit
						</a>
						<p class="opacity-70">
							Last modified: {lastModified}
						</p>
					</div>

					<!-- Ensemble response + Comments -->
					<EnsembleResponse />
					<CommentsGiscus />

					{morePosts.length > 0 && (
						<section class="mt-16 pt-8 border-t border-foreground/10 dark:border-foreground-dark/10">
							<h2 class="font-display text-lg tracking-[0.02em] text-foreground/60 dark:text-foreground-dark/60 font-normal mb-6">More from this track</h2>
							<div class="grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
								{morePosts.map((post) => (
									<BlogCard post={post} />
								))}
							</div>
						</section>
					)}
				</div>
			</div>
		</article>
	</main>
</BaseLayout>
