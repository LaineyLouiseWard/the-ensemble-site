---
import FormattedDate from './FormattedDate.astro'
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import { getEntry } from 'astro:content'
import { TRACKS } from '../consts'

const { post } = Astro.props

const blogImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/blogimages/**/*.{jpeg,jpg,png,gif}'
)

const coverImagePath = `/src/assets/blogimages/${post.slug}/cover.jpg`

const authors = await Promise.all(
	(post.data.authors || []).map((id: string) => getEntry('authors', id))
)
const resolvedAuthors = authors.filter(Boolean)
const authorNames = resolvedAuthors.map((a) => a.data.name).join(', ')
const trackLabel = TRACKS.find((t) => t.slug === post.data.track)?.label
---

<a
	href={`/blog/${post.slug}/`}
	class="flex flex-col gap-2.5 h-full group transition-colors"
>
	{
		blogImages[coverImagePath] && (
			<Image
				src={blogImages[coverImagePath]()}
				alt={post.data.title}
				class="object-cover rounded-lg aspect-video mb-1"
			/>
		)
	}
	{
		trackLabel && (
			<span class="font-meta text-[10px] uppercase tracking-[0.15em] text-foreground/70 dark:text-foreground-dark/70 font-medium">
				{trackLabel}
			</span>
		)
	}
	<h4
		class="font-display text-base font-normal leading-[1.35] group-hover:text-primary dark:group-hover:text-primary-dark transition-colors"
	>
		{post.data.title}
	</h4>
	<p class="font-meta text-[10px] mt-auto pt-1 uppercase tracking-[0.15em] text-foreground/60 dark:text-foreground-dark/60 font-medium">
		By {authorNames || 'Staff'}
	</p>
</a>
