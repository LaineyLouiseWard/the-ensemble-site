---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import { getEntry } from 'astro:content'
import { TRACKS } from '../consts'

const { post } = Astro.props

const blogImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/blogimages/**/*.{jpeg,jpg,png,gif}'
)

const coverImagePath = blogImages[`/src/assets/blogimages/${post.slug}/cover.jpg`]
	? `/src/assets/blogimages/${post.slug}/cover.jpg`
	: `/src/assets/blogimages/${post.slug}/cover.png`

const authors = await Promise.all(
	(post.data.authors || []).map((id: string) => getEntry('authors', id))
)
const resolvedAuthors = authors.filter(Boolean)
const authorNames = resolvedAuthors.map((a) => a.data.name).join(', ')
const trackLabel = TRACKS.find((t) => t.slug === post.data.track)?.label
---

<a
	href={`/blog/${post.slug}/`}
	class="flex flex-col gap-2.5 h-full group transition-all hover:border-dashed hover:border-foreground/25 dark:hover:border-foreground-dark/25 border-2 border-transparent rounded-none p-2 -m-2"
	style="image-rendering: pixelated;"
>
	{
		blogImages[coverImagePath] && (
			<Image
				src={blogImages[coverImagePath]()}
				alt={post.data.title}
				class="w-full object-cover rounded-lg aspect-video mb-1"
			/>
		)
	}
	<h4
		class="flex-1 font-display text-lg font-normal leading-[1.35] group-hover:text-primary dark:group-hover:text-primary-dark transition-colors"
	>
		{post.data.title}
	</h4>
	<div class="flex items-center gap-2 mt-auto pt-1">
		{
			trackLabel && (
				<span class="font-meta text-[14px] uppercase tracking-[0.15em] text-foreground/70 dark:text-foreground-dark/70 font-medium">
					{trackLabel}
				</span>
			)
		}
		{trackLabel && <span class="text-foreground/30 dark:text-foreground-dark/30 text-[14px]">·</span>}
		<p class="font-meta text-[14px] uppercase tracking-[0.15em] text-foreground/60 dark:text-foreground-dark/60 font-medium">
			By {authorNames || 'Staff'}
		</p>
	</div>
</a>
