---
import FormattedDate from './FormattedDate.astro'
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import { getEntry } from 'astro:content'
import { TRACKS } from '../consts'

const { post } = Astro.props

const blogImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/blogimages/**/*.{jpeg,jpg,png,gif}'
)

const coverImagePath = `/src/assets/blogimages/${post.slug}/cover.jpg`

const authors = await Promise.all(
	(post.data.authors || []).map((id: string) => getEntry('authors', id))
)
const resolvedAuthors = authors.filter(Boolean)
const authorNames = resolvedAuthors.map((a) => a.data.name).join(', ')

const trackLabel = TRACKS.find((t) => t.slug === post.data.track)?.label
---

<a
	href={`/blog/${post.slug}/`}
	class="block group relative overflow-hidden rounded-xl aspect-[4/3] sm:aspect-[16/10]"
>
	{
		blogImages[coverImagePath] ? (
			<Image
				src={blogImages[coverImagePath]()}
				alt={post.data.title}
				class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
			/>
		) : (
			<div class="absolute inset-0 bg-foreground/10 dark:bg-foreground-dark/10" />
		)
	}
	<div
		class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"
	>
	</div>
	<div class="absolute bottom-0 left-0 right-0 p-7 sm:p-10 text-white">
		{
			trackLabel && (
				<span class="text-[11px] uppercase tracking-[0.3em] text-white/60 mb-4 block font-medium">
					{trackLabel}
				</span>
			)
		}
		<h3
			class="font-display text-xl sm:text-2xl lg:text-[1.75rem] font-normal leading-[1.25] mb-3"
		>
			{post.data.title}
		</h3>
		<p class="text-[11px] text-white/60 font-medium tracking-[0.2em] uppercase">
			By {authorNames || 'Staff'}
		</p>
	</div>
</a>
