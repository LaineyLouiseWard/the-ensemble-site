---
/**
 * Pixel-art parallax hero with 4 layers.
 *
 * Layer classification:
 *   1.png = sky gradient   (back, no drift)
 *   2.png = clouds         (drifts RIGHT, slow)
 *   3.png = distant land   (LAND-FAR  — drifts LEFT, opposite clouds)
 *   4.png = close trees    (TREES     — drifts LEFT, same as land, -120px offset)
 *
 * Direction rules:
 *   clouds  → RIGHT (+576px)
 *   land    → LEFT  (-576px)  — opposite to clouds
 *   trees   → LEFT  (-576px)  — same as land, offset -120px
 *
 * Zoom: .parallax-scene scaled 1.1× from top-center.
 * Reduced motion: drift stopped, zoom preserved.
 */
---

<div class="parallax-hero relative w-full min-h-[60vh] sm:min-h-[68vh] lg:min-h-[70vh] overflow-hidden">
	<!-- Sky wrapper (furthest back) -->
	<div class="parallax-scene absolute inset-0">
		<div
			class="parallax-layer absolute inset-0"
			data-layer="1"
			data-speed="0"
			style="background: url('/parallax/1.png') repeat-x center bottom / auto 100%;"
		></div>
	</div>

	<!-- Sun / Moon — sits between sky and overlay -->
	<div class="absolute top-[100px] right-[104px] sm:right-[120px]" style="z-index: 5; pointer-events: none;">
		<img
			src="/icons/ui/sun-hero.png"
			alt=""
			class="celestial-sun h-14 sm:h-16 w-auto"
			style="image-rendering: pixelated;"
		/>
		<img
			src="/icons/ui/moon-hero.png"
			alt=""
			class="celestial-moon absolute inset-0 h-14 sm:h-16 w-auto"
			style="image-rendering: pixelated;"
		/>
	</div>

	<!-- Dark overlay for text readability -->
	<div class="absolute inset-0 bg-black/30 dark:bg-black/50" style="z-index: 6;"></div>

	<!-- Top-edge gradient for nav blending -->
	<div class="absolute inset-x-0 top-0 h-28 bg-gradient-to-b from-black/30 to-transparent" style="z-index: 7;"></div>

	<!-- Content slot — z-index: 8 -->
	<div class="relative h-full" style="z-index: 8;">
		<slot />
	</div>

	<!-- Cloud overlay: above nav (z-40) and title (z-8), clicks pass through -->
	<div class="parallax-scene absolute inset-0" style="z-index: 50; pointer-events: none;">
		<div
			class="parallax-layer absolute inset-0"
			data-layer="2"
			data-speed="0.015"
			data-drift-dur="240"
			data-drift-dir="1"
			data-drift-x="300"
			style="background: url('/parallax/2.png') repeat-x 300px bottom / auto 100%;"
		></div>
	</div>

	<!-- Ground overlay: above cloud (z-55), clicks pass through -->
	<div class="parallax-scene absolute inset-0" style="z-index: 55; pointer-events: none;">
		<div
			class="parallax-layer absolute inset-0"
			data-layer="3"
			data-speed="0.03"
			data-drift-dur="130"
			data-drift-dir="-1"
			data-drift-x="0"
			style="background: url('/parallax/3.png') repeat-x center bottom / auto 100%;"
		></div>
		<div
			class="parallax-layer absolute inset-0"
			data-layer="4"
			data-speed="0.05"
			data-drift-dur="60"
			data-drift-dir="-1"
			data-drift-x="-120"
			style="background: url('/parallax/4.png') repeat-x -120px bottom / auto 100%;"
		></div>
	</div>
</div>

<style>
	/* Subtle zoom to reduce visible tiling. Scale from top-center
	   so cloud peaks keep breathing room. */
	.parallax-scene {
		transform: scale(1.1);
		transform-origin: center top;
		will-change: transform;
	}

	/* Pixel art must stay crisp */
	.parallax-layer {
		image-rendering: pixelated;
		image-rendering: -moz-crisp-edges;
		will-change: transform;
	}

	/* Sun / Moon slide transition — use transform (not Tailwind translate)
	   so the transition property fires correctly. */
	.celestial-sun,
	.celestial-moon {
		transition: transform 0.8s cubic-bezier(0.85, 0, 0.15, 1);
	}

	/* Light mode: sun visible, moon hidden below ground */
	.celestial-sun  { transform: translateY(0); }
	.celestial-moon { transform: translateY(120vh) scaleX(-1); }

	/* Dark mode: sun hidden below ground, moon visible (same height as sun) */
	:global(.dark) .celestial-sun  { transform: translateY(120vh); }
	:global(.dark) .celestial-moon { transform: translateY(0) scaleX(-1); }

	/* Reduced motion: JS skips drift + scroll; keep zoom */
	@media (prefers-reduced-motion: reduce) {
		.parallax-layer {
			will-change: auto;
		}
		.celestial-sun,
		.celestial-moon {
			transition: none;
		}
	}
</style>

<script>
	function initParallax() {
		const hero = document.querySelector('.parallax-hero') as HTMLElement | null
		if (!hero) return

		const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
		if (prefersReduced) return

		const layers = hero.querySelectorAll<HTMLElement>('.parallax-layer[data-speed]')
		const driftLayers = hero.querySelectorAll<HTMLElement>('.parallax-layer[data-drift-dur]')

		// Native tile aspect ratio (576×324)
		const TILE_RATIO = 576 / 324
		const startTime = performance.now()
		let rafId = 0

		function frame(now: number) {
			const rect = hero!.getBoundingClientRect()
			const heroHeight = rect.height
			const heroTop = rect.top

			// Vertical scroll parallax
			const progress = Math.max(0, Math.min(1,
				(window.innerHeight - heroTop) / (window.innerHeight + heroHeight)
			))
			const scrollOffset = (progress - 0.5)

			layers.forEach((layer) => {
				const speed = parseFloat(layer.dataset.speed || '0')
				const y = scrollOffset * speed * heroHeight
				layer.style.transform = `translate3d(0, ${y}px, 0)`
			})

			// Horizontal drift using actual rendered tile width
			const elapsed = (now - startTime) / 1000

			const tileWidth = heroHeight * TILE_RATIO

			driftLayers.forEach((layer) => {
				const dur = parseFloat(layer.dataset.driftDur!)
				const dir = parseFloat(layer.dataset.driftDir!)
				const x0 = parseFloat(layer.dataset.driftX!)
				const drift = ((elapsed / dur) % 1) * tileWidth * dir
				layer.style.backgroundPositionX = `${x0 + drift}px`
			})

			rafId = requestAnimationFrame(frame)
		}

		rafId = requestAnimationFrame(frame)

		// Cleanup on page swap (Astro SPA)
		document.addEventListener('astro:before-swap', () => cancelAnimationFrame(rafId), { once: true })
	}

	initParallax()
	document.addEventListener('astro:after-swap', initParallax)
</script>
