<div id="ensemble-response" class="mb-6 border border-foreground/15 dark:border-foreground-dark/15 rounded-lg px-4 py-3 inline-flex items-center gap-3">
	<span class="font-meta text-[11px] uppercase tracking-[0.15em] text-foreground/40 dark:text-foreground-dark/40 font-medium">Ensemble response</span>
	<span id="ensemble-response-text" class="text-sm font-medium text-foreground/70 dark:text-foreground-dark/70">…</span>
</div>

<script is:inline>
(function () {
	var el = document.getElementById('ensemble-response')
	var textEl = document.getElementById('ensemble-response-text')
	if (!el || !textEl) return

	var pathname = window.location.pathname

	fetch('/api/ensemble?pathname=' + encodeURIComponent(pathname))
		.then(function (res) {
			if (!res.ok) throw new Error(res.status)
			return res.json()
		})
		.then(function (data) {
			if (data.total === 0) {
				textEl.textContent = 'No reactions yet'
			} else {
				textEl.innerHTML =
					'<span style="color:#4abe7a">' + data.up + ' Converge</span>' +
					' \u00b7 ' +
					'<span style="color:#d4a24e">' + data.down + ' Diverge</span>'
			}
		})
		.catch(function () {
			el.style.display = 'none'
		})
})()
</script>
